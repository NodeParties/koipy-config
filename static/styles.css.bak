@import url("https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Fira+Sans:wght@300;400;500;600;700&display=swap");

:root {
  --color-primary: #2563eb;
  --color-secondary: #3b82f6;
  --color-cta: #f97316;
  --color-background: #f8fafc;
  --color-text: #1e293b;

  --primary-rgb: 37, 99, 235;
  --secondary-rgb: 59, 130, 246;
  --accent-rgb: 249, 115, 22;

  --bg: var(--color-background);
  --surface: #ffffff;
  --surface-solid: #ffffff;
  --surface-soft: #f1f5f9;
  --line: #e2e8f0;
  --line-strong: #cbd5e1;
  --text: var(--color-text);
  --text-secondary: #334155;
  --text-soft: #475569;
  --text-muted: #64748b;
  --primary: var(--color-primary);
  --primary-strong: #1d4ed8;
  --primary-soft: rgba(var(--primary-rgb), 0.12);
  --accent: var(--color-cta);
  --accent-strong: #ea580c;
  --accent-soft: rgba(var(--accent-rgb), 0.14);
  --danger: #ef4444;
  --danger-soft: rgba(239, 68, 68, 0.14);
  --success: #22c55e;
  --warning: var(--accent);
  --info: var(--color-secondary);
  --code: #0f172a;
  --code-text: #dbeafe;
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.1);
  --shadow-xl: 0 20px 25px rgba(0, 0, 0, 0.15);
  --radius: 8px;
  --radius-lg: 12px;
  --font-ui: "Fira Sans", "Segoe UI", "Microsoft YaHei UI", "PingFang SC", sans-serif;
  --font-mono: "Fira Code", "Cascadia Code", "SFMono-Regular", Consolas, monospace;
  --focus: 0 0 0 3px rgba(var(--primary-rgb), 0.24);
  --space-xs: 4px;
  --space-sm: 8px;
  --space-md: 16px;
  --space-lg: 24px;
  --space-xl: 32px;
  --space-2xl: 48px;
  --space-3xl: 64px;
  --space-control: 10px;
  --space-field: 12px;
  --space-block: 14px;
  --space-panel: 18px;
  --space-stack: 20px;
  --transition-fast: 150ms ease;
  --transition: 200ms ease;
}

* {
  box-sizing: border-box;
}

html {
  min-width: 320px;
  color: var(--text);
  background: var(--bg);
  font-family: var(--font-ui);
  font-size: 16px;
  line-height: 1.5;
}

body {
  min-height: 100dvh;
  margin: 0;
  background:
    radial-gradient(circle at 12% -6%, rgba(var(--primary-rgb), 0.1), transparent 30rem),
    radial-gradient(circle at 96% 4%, rgba(var(--secondary-rgb), 0.12), transparent 24rem),
    linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
}

button,
input,
select,
textarea {
  font: inherit;
}

button {
  min-height: 44px;
  border: 0;
  cursor: pointer;
  touch-action: manipulation;
}

button:disabled,
input:disabled,
select:disabled,
textarea:disabled {
  cursor: not-allowed;
  opacity: 0.48;
}

button:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible,
a:focus-visible {
  outline: none;
  box-shadow: var(--focus);
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  margin-bottom: 0;
  font-size: 1.15rem;
}

h2 {
  margin-bottom: 6px;
  font-size: clamp(1.55rem, 3vw, 2.45rem);
  line-height: 1.12;
}

h3 {
  margin-bottom: 0;
  font-size: 1.08rem;
}

code,
.code-editor {
  font-family: var(--font-mono);
}

.skip-link {
  position: fixed;
  top: var(--space-field);
  left: var(--space-field);
  z-index: 2000;
  padding: var(--space-control) var(--space-block);
  border-radius: var(--radius);
  background: var(--code);
  color: white;
  transform: translateY(-160%);
  transition: transform 180ms ease;
}

.skip-link:focus {
  transform: translateY(0);
}

.app-shell {
  display: grid;
  grid-template-columns: 308px minmax(0, 1fr);
  min-height: 100dvh;
}

.sidebar {
  position: sticky;
  top: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  height: 100dvh;
  padding: var(--space-panel);
  border-right: 1px solid var(--line);
  background: rgba(248, 250, 252, 0.92);
  overflow: hidden;
}

.brand-panel,
.sidebar-card,
.panel,
.advanced-panel,
.inspector,
.result-panel,
.hero-panel,
.metric,
.status-strip article {
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  background: var(--surface);
  box-shadow: var(--shadow-sm);
}

.brand-panel {
  display: flex;
  gap: var(--space-field);
  align-items: center;
  padding: var(--space-block);
  border-radius: var(--radius-lg);
}

.brand-mark {
  display: grid;
  flex: 0 0 auto;
  width: 48px;
  height: 48px;
  place-items: center;
  border-radius: var(--radius-lg);
  background: linear-gradient(145deg, var(--primary-strong), var(--primary));
  box-shadow: 0 10px 24px rgba(var(--primary-rgb), 0.24);
}

.brand-mark img {
  width: 32px;
  height: 32px;
  object-fit: contain;
}

.brand-mark svg,
.input-with-icon svg,
.icon-button svg {
  fill: none;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 2;
}

.brand-mark svg {
  width: 30px;
  height: 30px;
  color: white;
}

.eyebrow {
  margin: 0 0 4px;
  color: var(--primary-strong);
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 800;
  text-transform: uppercase;
}

.search-control {
  display: grid;
  gap: 7px;
  position: relative;
  z-index: 40;
}

.search-control label,
.field-label,
.access-field > label:first-child {
  color: var(--text-soft);
  font-size: 0.82rem;
  font-weight: 800;
}

.input-with-icon {
  position: relative;
}

.input-with-icon svg {
  position: absolute;
  top: 50%;
  left: 12px;
  width: 20px;
  height: 20px;
  color: var(--text-muted);
  transform: translateY(-50%);
}

input,
select,
textarea {
  width: 100%;
  min-height: 44px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #ffffff;
  color: var(--text);
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
}

input,
select {
  padding: 10px 12px;
}

textarea {
  padding: 12px;
  resize: vertical;
}

.json-field {
  background: #f8fafc;
  font-family: var(--font-mono);
  line-height: 1.55;
}

.input-with-icon input {
  padding-left: 42px;
}

.search-results-panel {
  position: absolute;
  top: calc(100% + var(--space-sm));
  left: 0;
  right: 0;
  max-height: min(52vh, 420px);
  overflow: auto;
  padding: var(--space-sm);
  border: 1px solid var(--line-strong);
  border-radius: var(--radius);
  background: var(--surface-solid);
  box-shadow: var(--shadow-lg);
}

.search-results-panel .panel-heading {
  margin-bottom: var(--space-sm);
}

.search-results-panel .search-list {
  gap: var(--space-sm);
}

.search-results-panel .search-row {
  min-height: 42px;
  padding: 8px 10px;
  align-items: flex-start;
}

.section-nav {
  display: grid;
  gap: 8px;
  overflow: auto;
  padding-right: 2px;
  scrollbar-color: var(--line-strong) transparent;
}

.nav-item {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 10px;
  align-items: center;
  width: 100%;
  min-height: 58px;
  padding: 10px 11px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #ffffff;
  color: var(--text-soft);
  text-align: left;
  transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
}

.nav-item:hover {
  border-color: rgba(var(--primary-rgb), 0.36);
  background: #f7faff;
  transform: translateX(1px);
}

.nav-item[aria-current="true"] {
  border-color: rgba(var(--primary-rgb), 0.45);
  background: linear-gradient(135deg, rgba(var(--primary-rgb), 0.12), rgba(var(--secondary-rgb), 0.08));
  color: var(--text);
  box-shadow: inset 0 0 0 1px rgba(var(--primary-rgb), 0.08);
}

.nav-item span {
  display: grid;
  gap: 2px;
  min-width: 0;
}

.nav-item strong,
.nav-item small {
  overflow: hidden;
  text-overflow: ellipsis;
}

.nav-item strong {
  color: inherit;
  white-space: nowrap;
}

.nav-item small {
  display: -webkit-box;
  color: var(--text-muted);
  font-size: 0.74rem;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.nav-item em,
.count-pill,
.type-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 26px;
  padding: 4px 8px;
  border-radius: 999px;
  border: 1px solid rgba(var(--primary-rgb), 0.2);
  background: rgba(var(--primary-rgb), 0.08);
  color: var(--primary-strong);
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-style: normal;
  font-weight: 800;
}

.sidebar-card {
  display: grid;
  gap: var(--space-field);
  padding: var(--space-field);
}

.connection-card {
  gap: var(--space-control);
}

.connection-card-head {
  display: grid;
  gap: var(--space-sm);
}

.mini-status {
  display: inline-flex;
  gap: 10px;
  align-items: center;
}

.mini-status strong {
  line-height: 1;
  font-size: 0.98rem;
  font-weight: 800;
}

.mini-status small {
  color: var(--text-muted);
}

.status-dot {
  display: inline-block;
  flex: 0 0 auto;
  width: 12px;
  height: 12px;
  border-radius: 999px;
  background: var(--warning);
  box-shadow: 0 0 0 5px rgba(var(--accent-rgb), 0.18);
}

.status-dot.online {
  background: var(--success);
  box-shadow: 0 0 0 5px rgba(34, 197, 94, 0.18);
}

.status-dot.error {
  background: var(--danger);
  box-shadow: 0 0 0 5px rgba(239, 68, 68, 0.18);
}

.connection-card-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-sm);
}

.connection-stat {
  display: grid;
  gap: 3px;
  padding: 8px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--surface-soft);
}

.connection-stat span {
  color: var(--text-muted);
  font-size: 0.72rem;
  font-weight: 700;
  line-height: 1.2;
}

.connection-stat strong {
  color: var(--text);
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

#nav-health-latency {
  transition: color var(--transition-fast);
}

#nav-health-latency[data-tone="good"] {
  color: var(--success);
}

#nav-health-latency[data-tone="warn"] {
  color: var(--accent);
}

#nav-health-latency[data-tone="bad"] {
  color: var(--danger);
}

#nav-health-latency[data-tone="pending"],
#nav-health-latency[data-tone="unknown"] {
  color: var(--text-soft);
}

.main {
  min-width: 0;
  padding: var(--space-lg);
}

.topbar {
  display: grid;
  gap: var(--space-md);
  margin-bottom: var(--space-md);
}

.topbar-title p:last-child {
  max-width: 74ch;
  margin-bottom: 0;
  color: var(--text-soft);
}

.topbar-controls {
  display: grid;
  gap: var(--space-control);
  width: 100%;
  justify-items: stretch;
}

.action-row-main {
  justify-content: flex-start;
}

.connection-bar {
  display: grid;
  gap: var(--space-panel);
  align-items: start;
  padding: var(--space-panel);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  background: var(--surface);
  box-shadow: var(--shadow-sm);
}

.connection-head {
  display: flex;
  gap: var(--space-md);
  align-items: flex-start;
  justify-content: space-between;
}

.connection-head h3 {
  margin: 0;
  font-size: 1rem;
}

.connection-state {
  display: inline-flex;
  gap: 6px;
  align-items: center;
  margin: 0;
  color: var(--text-muted);
  font-size: 0.82rem;
  font-weight: 700;
}

.connection-state strong {
  color: var(--warning);
  font-family: var(--font-mono);
  font-size: 0.8rem;
}

.connection-bar[data-health="online"] .connection-state strong {
  color: var(--success);
}

.connection-bar[data-health="error"] .connection-state strong {
  color: var(--danger);
}

.connection-grid {
  display: grid;
  grid-template-columns: minmax(320px, 1.25fr) minmax(300px, 1fr);
  gap: var(--space-md);
}

.connection-field {
  display: grid;
  gap: 6px;
  align-content: start;
}

.api-field,
.access-field {
  display: grid;
  gap: 6px;
  width: 100%;
}

.api-field small {
  color: var(--text-muted);
  font-size: 0.78rem;
  font-weight: 600;
}

.secret-input {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 44px;
  gap: 6px;
}

.remember-access {
  display: inline-flex;
  gap: 7px;
  align-items: center;
  color: var(--text-muted);
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
}

.remember-access input {
  width: 16px;
  height: 16px;
  margin: 0;
}

.action-row-danger {
  width: 100%;
  padding-top: var(--space-sm);
  border-top: 1px dashed var(--line-strong);
  justify-content: flex-end;
}

.action-row-danger .button {
  min-width: 168px;
}

.button,
.icon-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius);
  font-weight: 700;
  transition: transform var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast), border-color var(--transition-fast);
}

.button {
  gap: 8px;
  padding: 10px 15px;
  border: 1px solid transparent;
  background: var(--surface-soft);
  color: var(--text);
}

.button.primary {
  background: var(--primary);
  color: white;
  box-shadow: 0 6px 16px rgba(var(--primary-rgb), 0.25);
}

.button.accent {
  background: var(--accent);
  color: #ffffff;
  box-shadow: 0 6px 16px rgba(var(--accent-rgb), 0.24);
}

.button.secondary {
  border: 1px solid var(--line);
  background: #ffffff;
  color: var(--text);
}

.button.tool-button {
  border-color: rgba(var(--accent-rgb), 0.34);
  background: rgba(var(--accent-rgb), 0.1);
  color: #92400e;
}

.button.danger,
.icon-button.danger {
  border-color: rgba(239, 68, 68, 0.28);
  background: var(--danger-soft);
  color: #b91c1c;
}

.button:hover,
.icon-button:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-md);
}

.button.primary:hover {
  background: var(--primary-strong);
}

.button.accent:hover {
  background: var(--accent-strong);
}

.button.secondary:hover {
  border-color: rgba(100, 116, 139, 0.45);
  background: #f8fafc;
}

.button.full {
  width: 100%;
}

.icon-button {
  width: 44px;
  min-width: 44px;
  padding: 0;
  border: 1px solid var(--line);
  background: #ffffff;
  color: var(--text-soft);
}

.icon-button svg {
  width: 20px;
  height: 20px;
}

.action-row,
.editor-toolbar,
.hero-actions,
.toolbar-line,
.modal-actions,
.inspector-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-control);
}

.status-strip {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: var(--space-control);
  margin-bottom: var(--space-md);
}

.status-strip article {
  min-height: 84px;
  padding: 14px;
  border-radius: var(--radius-lg);
}

.status-strip span,
.metric span,
.metric small {
  color: var(--text-muted);
  font-size: 0.78rem;
  font-weight: 800;
}

.status-strip strong,
.metric strong {
  display: block;
  margin-top: 8px;
  font-family: var(--font-mono);
  font-size: 1.25rem;
}

.workspace {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 360px;
  gap: var(--space-md);
  align-items: start;
}

.content-column {
  display: grid;
  gap: var(--space-md);
  min-width: 0;
}

.view-stack {
  display: grid;
  gap: var(--space-md);
}

.panel,
.advanced-panel,
.inspector,
.result-panel {
  padding: var(--space-panel);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
}

.inspector {
  position: sticky;
  top: var(--space-lg);
}

.panel-heading {
  display: flex;
  gap: var(--space-block);
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: var(--space-md);
}

.dashboard-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.6fr) repeat(3, minmax(150px, 0.6fr));
  gap: var(--space-block);
}

.hero-panel {
  padding: 22px;
  border-color: rgba(var(--primary-rgb), 0.3);
  background: linear-gradient(135deg, var(--primary-strong), var(--primary));
  color: white;
  box-shadow: var(--shadow-lg);
}

.hero-panel .eyebrow,
.hero-panel p {
  color: rgba(255, 255, 255, 0.86);
}

.hero-panel h3 {
  margin-bottom: 10px;
  font-size: 1.55rem;
}

.hero-panel .button.secondary {
  border-color: rgba(255, 255, 255, 0.35);
  background: rgba(255, 255, 255, 0.14);
  color: white;
}

.metric {
  min-height: 148px;
  padding: var(--space-panel);
}

.metric strong {
  margin: 12px 0 8px;
  font-size: 2.1rem;
  line-height: 1;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-block);
}

.form-grid.one {
  grid-template-columns: 1fr;
}

.field {
  display: grid;
  gap: var(--space-sm);
  align-content: start;
  min-width: 0;
}

.field.search-hit {
  animation: search-hit 1.2s ease;
}

.field.is-wide {
  grid-column: 1 / -1;
}

.field-meta {
  display: grid;
  gap: 3px;
}

.field-title {
  position: relative;
  display: inline-flex;
  gap: 6px;
  align-items: center;
  width: fit-content;
  max-width: 100%;
}

.field strong,
.array-heading strong,
.tag-editor strong {
  color: var(--text);
  font-size: 0.88rem;
}

.field small {
  color: var(--text-muted);
  font-size: 0.78rem;
}

.field mark {
  padding: 4px 6px;
  border-radius: var(--radius);
  background: var(--accent-soft);
  color: #9a3412;
  font-size: 0.74rem;
}

.help-tip {
  position: relative;
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  border: 1px solid rgba(var(--primary-rgb), 0.3);
  border-radius: 999px;
  background: rgba(var(--primary-rgb), 0.08);
  color: var(--primary-strong);
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 900;
  line-height: 1;
  cursor: help;
}

.help-tip:focus-visible {
  outline: none;
  box-shadow: var(--focus);
}

.help-popover {
  position: absolute;
  left: 50%;
  bottom: calc(100% + 9px);
  z-index: 80;
  width: min(320px, calc(100vw - 40px));
  padding: 10px 12px;
  border: 1px solid rgba(15, 23, 42, 0.2);
  border-radius: var(--radius);
  background: rgba(15, 23, 42, 0.97);
  color: #e2e8f0;
  box-shadow: var(--shadow-md);
  font-family: var(--font-ui);
  font-size: 0.78rem;
  font-weight: 600;
  line-height: 1.55;
  text-align: left;
  white-space: normal;
  opacity: 0;
  pointer-events: none;
  transform: translate(-50%, 4px);
  transition: opacity 160ms ease, transform 160ms ease;
}

.help-popover::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 100%;
  width: 10px;
  height: 10px;
  background: rgba(15, 23, 42, 0.97);
  transform: translate(-50%, -5px) rotate(45deg);
}

.help-tip:hover .help-popover,
.help-tip:focus .help-popover {
  opacity: 1;
  transform: translate(-50%, 0);
}

.field.is-dirty input,
.field.is-dirty select,
.field.is-dirty textarea {
  border-color: rgba(217, 119, 6, 0.54);
  background: #fffaf0;
}

.switch {
  position: relative;
  display: inline-flex;
  width: 52px;
  min-height: 44px;
  align-items: center;
}

.switch-with-help {
  display: inline-flex;
  gap: 8px;
  align-items: center;
}

.switch input {
  position: absolute;
  opacity: 0;
}

.switch span {
  position: relative;
  width: 48px;
  height: 28px;
  border-radius: 999px;
  background: #cbd5e1;
  transition: background 180ms ease;
}

.switch span::after {
  content: "";
  position: absolute;
  top: 4px;
  left: 4px;
  width: 20px;
  height: 20px;
  border-radius: 999px;
  background: white;
  box-shadow: var(--shadow-sm);
  transition: transform 180ms ease;
}

.switch input:checked + span {
  background: var(--primary);
}

.switch input:checked + span::after {
  transform: translateX(20px);
}

.array-editor,
.tag-editor {
  display: grid;
  grid-column: 1 / -1;
  gap: 10px;
  padding: 12px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #f8fafc;
}

.array-heading,
.toolbar-line {
  align-items: center;
  justify-content: space-between;
}

.array-heading {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.array-heading-actions {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  justify-content: flex-end;
}

.array-mode {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 6px;
  align-items: center;
}

.ghost-chip {
  min-height: 34px;
  padding: 6px 9px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: #ffffff;
  color: var(--text-soft);
  font-size: 0.78rem;
  font-weight: 800;
}

.ghost-chip.is-active {
  border-color: rgba(var(--primary-rgb), 0.38);
  background: rgba(var(--primary-rgb), 0.12);
  color: var(--primary-strong);
}

.toolbar-line span,
.muted {
  color: var(--text-muted);
  font-size: 0.86rem;
}

.array-list {
  display: grid;
  gap: 8px;
}

.array-item {
  display: grid;
  gap: 8px;
  padding: 8px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #ffffff;
}

.array-item.is-expanded {
  border-color: rgba(var(--primary-rgb), 0.34);
  background: #f7faff;
}

.array-summary,
.card-summary {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 10px;
  align-items: center;
  width: 100%;
  min-height: 44px;
  padding: 8px 10px;
  border-radius: var(--radius);
  color: var(--text);
  text-align: left;
}

.array-summary span,
.card-summary span {
  display: grid;
  gap: 2px;
  min-width: 0;
}

.array-summary strong,
.array-summary small,
.card-summary strong,
.card-summary small {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.array-summary small,
.card-summary small {
  color: var(--text-muted);
  font-size: 0.78rem;
}

.array-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 44px 44px 44px;
  gap: 8px;
}

.card-list {
  display: grid;
  gap: 12px;
  margin-top: 12px;
}

.item-card {
  display: grid;
  gap: 14px;
  padding: 14px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #ffffff;
}

.item-card header,
.item-card footer {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
  justify-content: space-between;
}

.item-card.is-expanded {
  border-color: rgba(var(--primary-rgb), 0.34);
  background: #f7faff;
}

.item-card header .card-summary {
  flex: 1 1 260px;
}

.card-header-actions {
  display: inline-flex;
  gap: 8px;
  align-items: center;
  justify-content: flex-end;
}

.compact-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tag-cloud label {
  cursor: pointer;
}

.tag-cloud input {
  position: absolute;
  opacity: 0;
}

.tag-cloud span {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  padding: 6px 10px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: #ffffff;
  color: var(--text-soft);
  font-size: 0.82rem;
}

.tag-cloud input:checked + span {
  border-color: rgba(var(--primary-rgb), 0.42);
  background: rgba(var(--primary-rgb), 0.12);
  color: var(--primary-strong);
  font-weight: 800;
}

.color-input {
  display: grid;
  grid-template-columns: 56px minmax(0, 1fr);
  gap: 8px;
}

.text-preset-input {
  display: grid;
  grid-template-columns: minmax(220px, 1.35fr) minmax(170px, 0.65fr);
  gap: 8px;
}

.resource-editor,
.color-stop-editor {
  display: grid;
  grid-column: 1 / -1;
  gap: 10px;
  padding: 12px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #f8fafc;
}

.resource-list,
.color-stop-list {
  display: grid;
  gap: 8px;
}

.resource-row {
  display: grid;
  grid-template-columns: minmax(120px, 0.36fr) minmax(260px, 1fr) 44px;
  gap: 8px;
  align-items: center;
  padding: 10px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #ffffff;
}

.resource-row input {
  min-width: 0;
}

.color-stop {
  display: grid;
  gap: 8px;
  padding: 8px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #ffffff;
}

.color-stop.is-expanded {
  border-color: rgba(var(--primary-rgb), 0.34);
  background: #f7faff;
}

.array-summary .color-stop-actions {
  display: inline-flex;
  gap: 8px;
  align-items: center;
}

.array-summary .color-stop-actions i {
  display: inline-block;
  width: 34px;
  height: 34px;
  border: 1px solid rgba(15, 23, 42, 0.18);
  border-radius: var(--radius);
  box-shadow: inset 0 0 0 3px rgba(255, 255, 255, 0.72);
}

.color-stop-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  padding: 8px;
}

.color-stop-footer {
  display: flex;
  grid-column: 1 / -1;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: flex-end;
  padding-top: 2px;
}

.color-input input[type="color"] {
  padding: 4px;
}

.gradient-preview {
  display: grid;
  gap: 8px;
  margin-bottom: 12px;
}

.gradient-preview div {
  height: 44px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
}

.gradient-preview span {
  color: var(--text-muted);
  font-size: 0.82rem;
  font-weight: 800;
}

.watermark-preview {
  display: grid;
  gap: 8px;
  min-height: 118px;
  margin-bottom: 14px;
  padding: 18px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(var(--primary-rgb), 0.12)),
    repeating-linear-gradient(45deg, rgba(var(--primary-rgb), 0.08) 0 8px, transparent 8px 16px);
}

.watermark-preview strong {
  font-size: 1.25rem;
}

.watermark-preview span {
  align-self: end;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

.risk-list,
.change-list,
.search-list,
.inspect-list {
  display: grid;
  gap: 10px;
}

.risk-item,
.change-item,
.search-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 10px;
  align-items: center;
  width: 100%;
  min-height: 48px;
  padding: 10px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #ffffff;
  color: var(--text);
  text-align: left;
}

.search-row > span {
  display: grid;
  gap: 2px;
  min-width: 0;
}

.search-row strong {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.25;
}

.search-row code {
  display: block;
  max-width: 100%;
  overflow: hidden;
  color: var(--text-muted);
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.25;
}

.search-row em {
  display: inline-flex;
  align-self: flex-start;
  padding: 3px 8px;
  border: 1px solid var(--line);
  border-radius: 999px;
  color: var(--text-soft);
  font-size: 0.72rem;
  font-style: normal;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.risk-item {
  border-color: rgba(var(--accent-rgb), 0.35);
  background: rgba(var(--accent-rgb), 0.08);
}

.change-item span {
  overflow: hidden;
  color: var(--text-muted);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.success-state,
.empty-state {
  padding: 18px;
  border: 1px dashed var(--line-strong);
  border-radius: var(--radius);
  background: #ffffff;
}

.success-state {
  color: var(--success);
  font-weight: 800;
}

.empty-state strong {
  display: block;
  margin-bottom: 4px;
}

.empty-state p {
  margin-bottom: 0;
  color: var(--text-muted);
}

.path-card {
  display: grid;
  gap: 10px;
  margin-bottom: 14px;
  padding: 12px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #f8fafc;
}

.path-card span {
  color: var(--text-muted);
  font-size: 0.78rem;
  font-weight: 800;
}

.path-card code {
  overflow-wrap: anywhere;
  color: var(--primary-strong);
  font-size: 0.86rem;
}

.inspect-list {
  margin: 0 0 14px;
}

.inspect-list div {
  display: grid;
  gap: 4px;
  padding: 10px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #f8fafc;
}

.inspect-list dt {
  color: var(--text-muted);
  font-size: 0.76rem;
  font-weight: 800;
}

.inspect-list dd {
  margin: 0;
  overflow-wrap: anywhere;
  font-family: var(--font-mono);
  font-size: 0.82rem;
}

.code-editor {
  min-height: 420px;
  border-color: rgba(15, 23, 42, 0.36);
  background: var(--code);
  color: var(--code-text);
  line-height: 1.55;
  tab-size: 2;
}

.code-editor.small {
  min-height: 240px;
}

.segmented {
  display: inline-grid;
  grid-template-columns: repeat(2, 1fr);
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #ffffff;
}

.segmented button {
  min-height: 38px;
  padding: 8px 12px;
  background: transparent;
  color: var(--text-secondary);
  font-weight: 800;
}

.segmented button.is-active {
  background: rgba(var(--primary-rgb), 0.12);
  color: var(--primary-strong);
}

.editor-toolbar {
  margin-bottom: 12px;
}

.skeleton-list {
  display: grid;
  gap: 10px;
}

.skeleton-list span {
  height: 54px;
  border-radius: var(--radius);
  background: linear-gradient(90deg, #e2e8f0, #f8fafc, #e2e8f0);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}

.toast-region {
  position: fixed;
  right: 18px;
  bottom: 18px;
  z-index: 1500;
  display: grid;
  gap: 10px;
  width: min(420px, calc(100vw - 36px));
  pointer-events: none;
}

.scroll-tools {
  position: fixed;
  right: 18px;
  bottom: 92px;
  z-index: 1200;
  display: grid;
  gap: 8px;
}

.scroll-tool {
  width: 46px;
  min-width: 46px;
  height: 46px;
  min-height: 46px;
  padding: 0;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: #ffffff;
  color: var(--primary-strong);
  box-shadow: var(--shadow-md);
  transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
}

.scroll-tool:hover {
  transform: translateY(-1px);
  background: rgba(var(--primary-rgb), 0.08);
  box-shadow: var(--shadow-md);
}

.scroll-tool svg {
  width: 22px;
  height: 22px;
  fill: none;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-width: 2.4;
}

.toast {
  display: grid;
  gap: 4px;
  padding: 14px 16px;
  border: 1px solid var(--line);
  border-left: 4px solid var(--success);
  border-radius: var(--radius);
  background: #ffffff;
  box-shadow: var(--shadow-md);
  animation: toast-in 200ms ease both;
}

.toast.error {
  border-left-color: var(--danger);
}

.toast.warning {
  border-left-color: var(--warning);
}

.toast span {
  color: var(--text-soft);
  font-size: 0.86rem;
}

.toast.is-leaving {
  opacity: 0;
  transform: translateY(8px) scale(0.98);
  transition: opacity 180ms ease, transform 180ms ease;
}

.modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 1400;
  display: grid;
  place-items: center;
  padding: 18px;
  background: rgba(15, 23, 42, 0.45);
}

.confirm-modal {
  width: min(460px, 100%);
  padding: 20px;
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  background: var(--surface-solid);
  box-shadow: var(--shadow-lg);
}

.confirm-modal p:not(.eyebrow) {
  color: var(--text-soft);
}

.tool-modal {
  display: grid;
  gap: 14px;
  width: min(620px, 100%);
  max-height: min(760px, calc(100dvh - 36px));
  overflow: auto;
  padding: 20px;
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  background: var(--surface-solid);
  box-shadow: var(--shadow-lg);
}

.tool-modal h3 {
  margin: 0;
}

.tool-modal form {
  display: grid;
  gap: 14px;
}

.tool-helper {
  margin: 0;
  color: var(--text-soft);
  font-size: 0.9rem;
}

.tool-preview {
  display: grid;
  gap: 10px;
  padding: 12px;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: #f8fafc;
}

.tool-preview-gradient {
  height: 52px;
  border: 1px solid rgba(15, 23, 42, 0.16);
  border-radius: var(--radius);
}

.tool-preview-stops {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
}

.tool-preview-stops span {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  min-height: 30px;
  padding: 4px 7px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: #ffffff;
}

.tool-preview-stops i {
  width: 16px;
  height: 16px;
  border: 1px solid rgba(15, 23, 42, 0.18);
  border-radius: 999px;
}

.tool-preview-stops code {
  color: var(--text-soft);
  font-size: 0.76rem;
}

.is-hidden {
  display: none !important;
}

::selection {
  background: rgba(var(--primary-rgb), 0.2);
  color: var(--text);
}

::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 6px;
}

::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

@keyframes shimmer {
  to {
    background-position: -200% 0;
  }
}

@keyframes toast-in {
  from {
    opacity: 0;
    transform: translateY(10px) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes search-hit {
  0% {
    background: rgba(var(--primary-rgb), 0.16);
  }
  100% {
    background: transparent;
  }
}

@media (max-width: 1280px) {
  .app-shell {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: relative;
    height: auto;
    border-right: 0;
    border-bottom: 1px solid var(--line);
  }

  .section-nav {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-height: none;
  }

  .search-results-panel {
    max-height: min(48vh, 360px);
  }

  .topbar-controls .action-row {
    justify-content: flex-start;
  }

  .connection-grid {
    grid-template-columns: 1fr;
  }

  .workspace {
    grid-template-columns: 1fr;
  }

  .inspector {
    position: relative;
    top: auto;
  }
}

@media (max-width: 900px) {
  .main,
  .sidebar {
    padding: var(--space-md);
  }

  .connection-bar {
    padding: var(--space-md);
  }

  .connection-head {
    flex-direction: column;
  }

  .status-strip,
  .dashboard-grid,
  .form-grid,
  .compact-grid,
  .color-stop-grid {
    grid-template-columns: 1fr;
  }

  .resource-row {
    grid-template-columns: minmax(0, 1fr) 44px;
  }

  .resource-row input:first-child {
    grid-column: 1 / -1;
  }

  .section-nav {
    grid-template-columns: 1fr;
  }

  .search-results-panel {
    position: static;
    max-height: 280px;
    margin-top: var(--space-sm);
  }

  .action-row > *,
  .editor-toolbar > *,
  .hero-actions > *,
  .inspector-actions > * {
    flex: 1 1 160px;
  }

  .item-card header small {
    white-space: normal;
  }
}

@media (max-width: 520px) {
  .brand-panel {
    align-items: flex-start;
  }

  .scroll-tools {
    right: 12px;
    bottom: 76px;
  }

  .scroll-tool {
    width: 44px;
    min-width: 44px;
    height: 44px;
    min-height: 44px;
  }

  .array-row {
    grid-template-columns: minmax(0, 1fr) 44px;
  }

  .array-row .icon-button {
    grid-row: auto;
  }

  .secret-input,
  .color-input,
  .text-preset-input {
    grid-template-columns: 1fr;
  }

  .icon-button {
    width: 100%;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: 0.01ms !important;
  }
}
